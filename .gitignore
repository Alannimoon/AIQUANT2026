AlphaAgent/alphaagent/scenarios/qlib/experiment/factor_data_template/*.h5

# Microsoft Qlib clone (reproducible; see scripts/README.md)
# Anchored with leading / so it doesn't match AlphaAgent/alphaagent/scenarios/qlib/
/qlib/

